<jasperReport name="relatorio_pedidos_emitidos" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c6cfb551-cec8-4140-b7d9-5149cb98dc0e">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Sample DB"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="data_inicio" class="java.util.Date"/>
	<parameter name="data_fim" class="java.util.Date"/>
	<query language="sql"><![CDATA[SELECT p.data_criacao AS data_criacao
	  ,p.valor_total AS valor_total
	  ,c.nome AS nome_cliente
	  ,u.nome AS nome_vendedor
	  ,p.id AS id
FROM pedido p
	INNER JOIN cliente c ON p.cliente_id = c.id
	INNER JOIN usuario u ON p.usuario_id = u.id
WHERE p.status = 'EMITIDA'
	AND p.data_criacao BETWEEN  $P{data_inicio}  AND  $P{data_fim}
ORDER BY p.data_criacao ASC]]></query>
	<field name="data_criacao" class="java.time.LocalDateTime">
		<property name="com.jaspersoft.studio.field.name" value="data_criacao"/>
		<property name="com.jaspersoft.studio.field.label" value="data_criacao"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="pedido"/>
	</field>
	<field name="valor_total" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="valor_total"/>
		<property name="com.jaspersoft.studio.field.label" value="valor_total"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="pedido"/>
	</field>
	<field name="nome_cliente" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nome"/>
		<property name="com.jaspersoft.studio.field.label" value="nome_cliente"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="cliente"/>
	</field>
	<field name="nome_vendedor" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nome"/>
		<property name="com.jaspersoft.studio.field.label" value="nome_vendedor"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="usuario"/>
	</field>
	<field name="id" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="id"/>
		<property name="com.jaspersoft.studio.field.label" value="id"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="pedido"/>
	</field>
	<variable name="valor_total1" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{valor_total}]]></expression>
	</variable>
