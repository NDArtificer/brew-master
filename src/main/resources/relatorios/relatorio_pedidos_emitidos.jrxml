<jasperReport name="relatorio_pedidos_emitidos"
			  language="java"
			  pageWidth="595"
			  pageHeight="842"
			  columnWidth="555"
			  leftMargin="20"
			  rightMargin="20"
			  topMargin="20"
			  bottomMargin="20">

	<!-- Parâmetros -->
	<parameter name="data_inicio" class="java.util.Date"/>
	<parameter name="data_fim" class="java.util.Date"/>
	<parameter name="logo" class="java.lang.Object"/>
	<parameter name="tipoRelatorio" class="java.lang.String"/>

	<!-- Query -->
	<query language="sql"><![CDATA[
        SELECT p.data_criacao AS data_criacao,
               p.valor_total AS valor_total,
               c.nome AS nome_cliente,
               u.nome AS nome_vendedor,
               p.id AS id
        FROM pedido p
        INNER JOIN cliente c ON p.cliente_id = c.id
        INNER JOIN usuario u ON p.usuario_id = u.id
        WHERE p.status = 'EMITIDA'
          AND p.data_criacao BETWEEN $P{data_inicio} AND $P{data_fim}
        ORDER BY p.data_criacao ASC
    ]]></query>

	<!-- Campos -->
	<field name="data_criacao" class="java.util.Date"/>
	<field name="valor_total" class="java.math.BigDecimal"/>
	<field name="nome_cliente" class="java.lang.String"/>
	<field name="nome_vendedor" class="java.lang.String"/>
	<field name="id" class="java.lang.Long"/>

	<!-- Variável total -->
	<variable name="valor_total1" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{valor_total}]]></expression>
	</variable>

	<!-- Cabeçalho -->
	<title height="100">
		<element kind="rectangle" x="0" y="0" width="555" height="80" backcolor="#003366"/>
		<element kind="image" x="10" y="10" width="120" height="70">
			<expression><![CDATA[$P{logo}]]></expression>
		</element>
		<element kind="staticText" x="0" y="15" width="555" height="25" fontSize="22" bold="true" hTextAlign="Center" forecolor="#FFFFFF">
			<text><![CDATA[Relatório]]></text>
		</element>
		<element kind="staticText" x="0" y="45" width="555" height="25" fontSize="18" bold="true" hTextAlign="Center" forecolor="#FFFFFF">
			<text><![CDATA[Pedidos Emitidos]]></text>
		</element>
	</title>

	<!-- Cabeçalho da tabela -->
	<columnHeader height="25">
		<element kind="rectangle" x="0" y="0" width="555" height="25" backcolor="#D0D0D0"/>
		<element kind="staticText" x="0" y="5" width="80" height="15" bold="true" hTextAlign="Center"><text><![CDATA[Data Criação]]></text></element>
		<element kind="staticText" x="90" y="5" width="50" height="15" bold="true" hTextAlign="Center"><text><![CDATA[Id]]></text></element>
		<element kind="staticText" x="150" y="5" width="160" height="15" bold="true" hTextAlign="Center"><text><![CDATA[Cliente]]></text></element>
		<element kind="staticText" x="320" y="5" width="120" height="15" bold="true" hTextAlign="Center"><text><![CDATA[Vendedor]]></text></element>
		<element kind="staticText" x="450" y="5" width="100" height="15" bold="true" hTextAlign="Center"><text><![CDATA[Valor Pedido]]></text></element>
	</columnHeader>

	<!-- Corpo com valores centralizados -->
	<detail>
		<band height="20">
			<element kind="rectangle" x="0" y="0" width="555" height="20" backcolor="#F5F5F5">
				<printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
			</element>
			<element kind="textField" x="0" y="2" width="80" height="15" pattern="dd/MM/yyyy" hTextAlign="Center">
				<expression><![CDATA[$F{data_criacao}]]></expression>
			</element>
			<element kind="textField" x="90" y="2" width="50" height="15" hTextAlign="Center">
				<expression><![CDATA[$F{id}]]></expression>
			</element>
			<element kind="textField" x="150" y="2" width="160" height="15" hTextAlign="Center" >
				<expression><![CDATA[$F{nome_cliente}]]></expression>
			</element>
			<element kind="textField" x="320" y="2" width="120" height="15" hTextAlign="Center">
				<expression><![CDATA[$F{nome_vendedor}]]></expression>
			</element>
			<element kind="textField" x="450" y="2" width="100" height="15" pattern="¤ #,##0.00;¤ -#,##0.00" hTextAlign="Center" >
				<expression><![CDATA[$F{valor_total}]]></expression>
			</element>
		</band>
	</detail>

	<!-- Resumo com somatório -->
	<summary height="40">
		<element kind="line" x="0" y="0" width="555" height="1" forecolor="#003366"/>
		<element kind="staticText" x="300" y="10" width="120" height="20" bold="true" hTextAlign="Right" forecolor="#003366">
			<text><![CDATA[Total:]]></text>
		</element>
		<element kind="textField" x="430" y="10" width="120" height="20" pattern="¤ #,##0.00;¤ -#,##0.00" bold="true" hTextAlign="Center" forecolor="#333333">
			<expression><![CDATA[$V{valor_total1}]]></expression>
		</element>
	</summary>

	<!-- Rodapé com página atual -->
	<pageFooter height="30">
		<element kind="line" x="0" y="0" width="555" height="1" forecolor="#003366"/>
		<element kind="textField" x="0" y="5" width="200" height="20" forecolor="#333333">
			<expression><![CDATA[new java.util.Date()]]></expression>
			<pattern>dd/MM/yyyy HH:mm</pattern>
		</element>
		<element kind="staticText" x="220" y="5" width="150" height="20" hTextAlign="Center" forecolor="#333333">
			<text><![CDATA[Sistema BrewMaster ERP]]></text>
		</element>
		<element kind="textField" x="400" y="5" width="150" height="20" hTextAlign="Right" forecolor="#333333">
			<expression><![CDATA["Página " + $V{PAGE_NUMBER}]]></expression>
		</element>
	</pageFooter>
</jasperReport>
